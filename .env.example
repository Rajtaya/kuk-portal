# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kuk_portal?schema=public"

# ─── JWT ─────────────────────────────────────────────────
# MUST be a strong, unique random value of at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Known placeholder values (incl. this example) are rejected at startup.
JWT_SECRET="change-me-to-a-32+char-random-secret"
JWT_EXPIRATION="8h"

# ─── Backend ─────────────────────────────────────────────
BACKEND_PORT=4000
# Comma-separated allowlist of origins permitted to send credentialed requests.
CORS_ORIGIN="http://localhost:3000"
# Trusted base URL used to build password-reset links (never derived from request headers).
FRONTEND_URL="http://localhost:3000"
# Optional explicit cookie scope; leave unset for the safest host-only default.
# COOKIE_DOMAIN=

# ─── Seed (local/test only) ──────────────────────────────
# Optional: choose the password the seed assigns to demo accounts. If unset, the seed
# generates a one-time random password and prints it. The seed refuses to run unless
# NODE_ENV is explicitly "development" or "test".
# SEED_ADMIN_PASSWORD="Choose-A-Strong-One1"

# ─── File Storage ────────────────────────────────────────
UPLOAD_DIR="./uploads"

# ─── SMTP (leave blank in dev — reset links print to the console) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="UEMS Portal <noreply@uems.kuk.ac.in>"

# ─── Google reCAPTCHA v2 ─────────────────────────────────
# Leave blank in dev (CAPTCHA is skipped). In production a missing key fails CLOSED.
RECAPTCHA_SECRET_KEY=
