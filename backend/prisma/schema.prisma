generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  STATE_USER
  UNIVERSITY_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Category {
  UR
  DSC
  OSC
  BCA
  BCB
  EWS
  PWD
}

enum PostType {
  BUDGETED
  SFS
  CONTRACTUAL
}

enum EmployeeClassification {
  TEACHING
}

enum EmploymentStatus {
  ACTIVE
  RETIRED
  RESIGNED
  TERMINATED
  SUSPENDED
}

enum DocumentType {
  APPOINTMENT_LETTER
  QUALIFICATION_CERTIFICATE
  SERVICE_BOOK
  OTHER
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  password     String
  name         String
  role         Role
  university   University? @relation(fields: [universityId], references: [id])
  universityId String?
  isActive      Boolean     @default(true)
  loginAttempts Int         @default(0)
  lockedUntil   DateTime?
  resetToken    String?
  resetTokenExp DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  auditLogs     AuditLog[]

  @@map("users")
}

// ─── Master Data ─────────────────────────────────────────

model University {
  id              String           @id @default(cuid())
  name            String           @unique
  code            String           @unique
  address         String?
  city            String?
  state           String?          @default("Haryana")
  website         String?
  email           String?
  phone           String?
  logoUrl         String?
  users           User[]
  departments     Department[]
  employees       Employee[]
  sanctionedPosts SanctionedPost[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("universities")
}

model Department {
  id              String           @id @default(cuid())
  name            String
  university      University       @relation(fields: [universityId], references: [id])
  universityId    String
  employees       Employee[]
  sanctionedPosts SanctionedPost[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([name, universityId])
  @@map("departments")
}

model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("subjects")
}

model Designation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("designations")
}

// ─── Employees ───────────────────────────────────────────

model Employee {
  id                     String                 @id @default(cuid())
  employeeId             String?                @unique
  name                   String
  gender                 Gender

  university             University             @relation(fields: [universityId], references: [id])
  universityId           String
  department             Department             @relation(fields: [departmentId], references: [id])
  departmentId           String
  subject                String?

  category               Category               @default(UR)
  categorySelection      Category               @default(UR)
  postType               PostType               @default(BUDGETED)
  employeeClassification EmployeeClassification @default(TEACHING)

  designationAppointed   String?
  designationPresent     String?

  dateOfBirth            DateTime?
  dateOfJoining          DateTime?
  retirementDate         DateTime?
  employmentStatus       EmploymentStatus       @default(ACTIVE)

  mobileNumber           String?
  email                  String?
  photoUrl               String?

  documents              Document[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([departmentId])
  @@index([postType])
  @@index([employeeClassification])
  @@index([employmentStatus])
  @@index([retirementDate])
  // Composite for the dominant access pattern: per-university active-employee
  // counts/aggregations (dashboard stats, university stats, scoped vacancy/charts).
  @@index([universityId, employmentStatus])
  @@map("employees")
}

// ─── Sanctioned Posts ────────────────────────────────────

model SanctionedPost {
  id             String     @id @default(cuid())
  university     University @relation(fields: [universityId], references: [id])
  universityId   String
  department     Department @relation(fields: [departmentId], references: [id])
  departmentId   String
  subject        String?
  designation    String
  postType       PostType   @default(BUDGETED)
  sanctionedCount Int       @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([universityId, departmentId, designation, subject, postType])
  @@map("sanctioned_posts")
}

// ─── Documents ───────────────────────────────────────────

model Document {
  id         String       @id @default(cuid())
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  type       DocumentType
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  createdAt  DateTime     @default(now())

  @@index([employeeId])
  @@map("documents")
}

// ─── Audit ───────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
